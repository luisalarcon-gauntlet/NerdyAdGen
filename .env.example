# ─────────────────────────────────────────────
# NERDY AD ENGINE — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your keys.
# ─────────────────────────────────────────────

# === REQUIRED FOR V1 ===
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LANGSMITH_API_KEY=your_langsmith_api_key_here

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ad_engine
DATABASE_URL_TEST=postgresql+asyncpg://postgres:postgres@db:5432/ad_engine_test

# === REQUIRED FOR V2 ===
NANO_BANANA_API_KEY=your_nano_banana_key_here

# === LANGSMITH ===
LANGSMITH_PROJECT=nerdy-ad-engine
LANGCHAIN_TRACING_V2=true
LANGSMITH_ENABLED=true

# === PIPELINE BEHAVIOUR ===
QUALITY_THRESHOLD=7.0
MAX_ITERATION_ATTEMPTS=7
CONFIDENCE_BAND=0.75
PIPELINE_VERSION=v1

# === HUMAN REVIEW ===
HUMAN_REVIEW_ENABLED=true
HUMAN_REVIEW_URGENCY_MINIMUM=low

# === LOGGING ===
LOG_FILE_PATH=data/pipeline.log

# === SCRAPING ===
META_ACCESS_TOKEN=your_meta_access_token_here
SCRAPING_DELAY_SECONDS=2.0
SCRAPING_JITTER_SECONDS=1.0

# === CALIBRATION (reference ads / annotate & calibrate CLI) ===
CALIBRATION_MIN_ANNOTATED=20
CALIBRATION_PASS_THRESHOLD=0.75
CALIBRATION_HALT_THRESHOLD=0.50
CALIBRATION_BAND_LOW_MAX=6.0
CALIBRATION_BAND_MEDIUM_MAX=7.5
CALIBRATION_BAND_HIGH_MAX=10.0
