## Interface Definitions

```python
class BaseAgent(ABC):
    version_required: ClassVar[str] = "v3"

    def _check_version(self) -> None:
        if settings.pipeline_version != self.version_required:
            raise NotImplementedError(
                f"{self.__class__.__name__} requires "
                f"PIPELINE_VERSION={self.version_required}. "
                f"Current: PIPELINE_VERSION={settings.pipeline_version}"
            )


class ResearcherAgent(BaseAgent):
    async def research(
        self,
        brief: Brief,
        competitor_ads: List[ScrapedAd],
        historical_ads: List[Ad],
    ) -> CreativeIntelligenceReport:
        self._check_version()
        # V3 implementation


class WriterAgent(BaseAgent):
    async def write(
        self,
        brief: Brief,
        intelligence: CreativeIntelligenceReport,
    ) -> Ad:
        self._check_version()
        # V3 implementation


class EditorAgent(BaseAgent):
    async def edit(
        self,
        ad: Ad,
        evaluation: EvaluationResult,
        strategy: RegenerationStrategy,
        brief: Brief,
    ) -> Ad:
        self._check_version()
        # V3 implementation


class EvaluatorAgent(BaseAgent):
    async def evaluate(
        self,
        ad: Ad,
        profile: WeightProfile,
    ) -> EvaluationResult:
        self._check_version()
        # V3 wraps src/evaluate/judge.py


class OrchestratorAgent(BaseAgent):
    async def run_brief(self, brief: Brief) -> OrchestratorResult:
        self._check_version()
        # V3 coordinates all other agents
```

