## settings.py — All Fields

```python
class Settings(BaseSettings):

    # API Keys
    gemini_api_key:          str
    anthropic_api_key:       str
    langsmith_api_key:       str
    nano_banana_api_key:     Optional[str] = None   # Required for V2

    # Database
    database_url:            str
    database_url_test:       Optional[str] = None   # Required for integration tests

    # LangSmith
    langsmith_project:       str  = "nerdy-ad-engine"
    langchain_tracing_v2:    bool = True
    langsmith_enabled:       bool = True

    # Pipeline behaviour
    quality_threshold:       float = 7.0
    max_iteration_attempts:  int   = 7
    confidence_band:         float = 0.75
    pipeline_version:        str   = "v1"     # "v1" | "v2" | "v3"

    # Human review
    human_review_enabled:             bool = True
    human_review_urgency_minimum:     str  = "low"   # "low" | "medium" | "high"

    # Logging
    log_file_path:           str   = "data/pipeline.log"

    # Scraping
    scraping_delay_seconds:  float = 2.0
    scraping_jitter_seconds: float = 1.0

    class Config:
        env_file = ".env"
        env_file_encoding = "utf-8"
        case_sensitive = False
```

