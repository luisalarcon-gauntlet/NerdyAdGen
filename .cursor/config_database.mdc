## docker-compose.yml (V1)

```yaml
version: "3.9"

services:
  app:
    build: .
    env_file: .env
    depends_on:
      db:
        condition: service_healthy
    command: >
      sh -c "alembic upgrade head && python main.py run --mode v1"
    volumes:
      - ./data:/app/data
      - ./reports:/app/reports

  db:
    image: postgres:15
    environment:
      POSTGRES_DB: ad_engine
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 5
    volumes:
      - postgres_data:/var/lib/postgresql/data

volumes:
  postgres_data:
```

