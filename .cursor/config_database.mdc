## Database Schema — V1 Tables

```sql
-- ads
id TEXT PRIMARY KEY, brief_id TEXT, status TEXT,
primary_text TEXT, headline TEXT, description TEXT, cta_button TEXT,
image_url TEXT, image_prompt TEXT,   -- always NULL in V1
final_score REAL, created_at TEXT, updated_at TEXT

-- briefs
id TEXT PRIMARY KEY, audience TEXT, campaign_goal TEXT, product TEXT,
hook_style TEXT, platform TEXT, offer TEXT, urgency TEXT, social_proof TEXT,
inferred_profile_id TEXT, inferred_length_target INT,
created_at TEXT

-- evaluations
id TEXT PRIMARY KEY, ad_id TEXT, attempt_number INT,
weighted_score REAL, knockout_passed BOOL, knockout_failures TEXT,  -- JSON array
requires_human_review BOOL, flags TEXT,   -- JSON array
confidence REAL, confidence_level TEXT,
created_at TEXT

-- dimension_scores
id TEXT PRIMARY KEY, evaluation_id TEXT, dimension TEXT,
score REAL, rationale TEXT, self_confidence REAL

-- iterations
id TEXT PRIMARY KEY, ad_id TEXT, attempt_number INT, tier TEXT,
target_dimension TEXT, strategy TEXT,
score_before REAL, score_after REAL,
dimensions_improved TEXT,   -- JSON array
dimensions_regressed TEXT,  -- JSON array
oscillation_detected BOOL,
cost_usd REAL, created_at TEXT

-- token_usage
id TEXT PRIMARY KEY, ad_id TEXT, brief_id TEXT,
operation TEXT,   -- "generation" | "evaluation" | "regeneration" | "calibration" | "image_generation"
provider TEXT, model TEXT,
input_tokens INT, output_tokens INT, cost_usd REAL,
created_at TEXT

-- reference_ads  (scraped competitor ads)
id TEXT PRIMARY KEY, ad_library_id TEXT UNIQUE, competitor TEXT,
primary_text TEXT, headline TEXT, description TEXT, cta_button TEXT,
platform TEXT, ad_format TEXT, is_active BOOL,
carousel_id TEXT, raw_html TEXT,
calibration_quality TEXT, calibration_score REAL,
scraped_at TEXT

-- batch_checkpoints
run_id TEXT, brief_id TEXT,
completed_at TEXT,
PRIMARY KEY (run_id, brief_id)

-- ratchet_history  (V3 stub — table exists in V1, never written to)
id TEXT PRIMARY KEY, previous_threshold REAL, new_threshold REAL,
trigger_avg_score REAL, window_size INT, created_at TEXT
